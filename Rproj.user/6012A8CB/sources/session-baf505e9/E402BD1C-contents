#Filter buildings through GPW
Building_filter <- function(merged_raster){
  sf_use_s2(FALSE)
  
  #Read building data
  if (!file.exists(file.path(data_path, "buildings", "NewYork.geojson.zip"))) {
    url <- "https://usbuildingdata.blob.core.windows.net/usbuildings-v2/NewYork.geojson.zip"
    destfile <- file.path(data_path, "buildings", "NewYork.geojson.zip")
    download.file(url, destfile, mode = "wb")
  }
  if (!file.exists(file.path(data_path, "buildings", "NewYork.geojson"))){
    unzip(destfile, exdir = file.path(data_path, "buildings"))
  }
  
  BUILDINGS <- st_read(file.path(data_path, "buildings", "NewYork.geojson")) 
  BUILDINGS_CENTROID <- st_centroid(BUILDINGS)
  
  # Project merged raster
  merged_raster_project <- terra::project(merged_raster, crs(BUILDINGS_CENTROID))
  # sum(merged_raster_project[], na.rm=T)
  building_with_pop <- exact_extract(merged_raster_project,BUILDINGS, append_cols = T, 
                                     fun = function(values,coverage_fractions){sum(values*coverage_fractions, na.rm = T)})
  
  building_pop <- building_with_pop$result
  building_area <- st_area(BUILDINGS)
  BUILDINGS_CENTROID$population <- building_pop
  BUILDINGS_CENTROID$area <- building_area
  
  gpw_filtered_buildings <- BUILDINGS_CENTROID[BUILDINGS_CENTROID$population > 0,]
  # st_write(gpw_filtered_buildings, 
  #          file.path(data_path, "buildings", "filtered_buildings.geojson"), 
  #          driver = "GeoJSON")
  
  ### Removing Buildings in <1 Person per Census Block According to Decennial ####
  # getting census data based on GEOGRAPHIC_RESOLUTION
  census_data <- GetCensusData_buildings("block") %>% mutate(occupied_ratio = Occupied/Total_units)

  # performing intersection between census_data and gpw_filtered_buildings
  census_buildings_intersect <- st_intersection(census_data, gpw_filtered_buildings)
  
  # removing buildings in census blocks with less than 1 person population
  census_filtered_buildings <- census_buildings_intersect[census_buildings_intersect$Total_pop >= 1, ] %>%
    mutate(occupied_ratio = ifelse(is.nan(occupied_ratio), 1, occupied_ratio)) %>%
    dplyr::select(GEOID,NAME, Total_pop, occupied_ratio)

  # renaming the variable to be more general
  filtered_buildings <- census_filtered_buildings
  
  # removing unused large files to free up space
  rm(gpw_filtered_buildings)
  rm(census_data)
  rm(census_buildings_intersect)
  rm(census_filtered_buildings)
  
  
  # Perform intersection between BUILDINGS spatial polygons and the filtered building centroids
  intersections <- st_intersects(BUILDINGS, filtered_buildings)
  
  # Checking where data intersects
  building_indices <- which(sapply(intersections, length) > 0)
  
  # Subsetting the building data to only where it intersects with population data
  cleaned_buildings <- BUILDINGS[building_indices, ]
  
  output_file <- file.path(data_path, "buildings", "cleaned_buildings.geojson")
  # st_write(cleaned_buildings, output_file, driver = "GeoJSON")
  return(cleaned_buildings)
}

