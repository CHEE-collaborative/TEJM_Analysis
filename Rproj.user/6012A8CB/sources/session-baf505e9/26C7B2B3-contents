# Fit Models
df <- 3
degree <- 2

year_month <- buildings_COM_energy$year_month
COM_CAT <- buildings_COM_energy$COM_CAT
COM_TYPE <- buildings_COM_energy$COM_TYPE
COM_NAME <- buildings_COM_energy$COM_NAME
energy <- sqrt(buildings_COM_energy$value)
low_basis <- bs(buildings_COM_energy$Low,df=df,degree=degree,intercept=F)
low_med_basis <- bs(buildings_COM_energy$`Low_medium`,df=df,degree=degree,intercept=F)
med_high_basis <- bs(buildings_COM_energy$Medium_High,df=df,degree=degree,intercept=F)

Low <- scale(buildings_COM_energy$Low)
Low_medium <- scale(buildings_COM_energy$Low_medium)
Medium_High <- scale(buildings_COM_energy$Medium_High)

Low_square <- Low^2
Low_medium_square <- Low_medium^2
Medium_High_square <- Medium_High^2

data_train <- data.frame(year_month = year_month,COM_TYPE = COM_TYPE, COM_NAME = COM_NAME,
                         energy = energy, Low = Low, Low_medium = Low_medium, Medium_High = Medium_High,
                         Low_square =  Low_square,Low_medium_square = Low_medium_square,Medium_High_square = Medium_High_square)
saveRDS(data_train, "/home/xz578/TEJM/TEJM-main/anna/data/prediction_model/data_train.rds")
# high_basis <- bs(buildings_COM_energy$High,df=df,degree=degree,intercept=F)

model2 <- lmer(energy ~ -1 + Low + Low_medium + Medium_High + 
                 (0+ Low + Low_medium + Medium_High|year_month)+
                 (0+ Low + Low_medium + Medium_High|COM_NAME),
               control = lmerControl(optCtrl = list(maxfun = 1e6)))
saveRDS(model2,"/home/xz578/TEJM/TEJM-main/anna/data/prediction_model/model_lmer_NAME.rds") #3 categories, combine medium to high

model3 <- lmer(energy ~ -1 + Low + Low_medium + Medium_High + Low_square + Low_medium_square + Medium_High_square+
                 (0+ Low + Low_medium + Medium_High + Low_square + Low_medium_square + Medium_High_square|year_month)+
                 (0+ Low + Low_medium + Medium_High + Low_square + Low_medium_square + Medium_High_square|COM_NAME),
               control = lmerControl(optCtrl = list(maxfun = 1e6)))
saveRDS(model3,"/home/xz578/TEJM/TEJM-main/anna/data/prediction_model/model_lmer_nonlinear_NAME.rds")#3 categories, combine medium to high

model1 <- lmer(energy ~ -1 + low_basis + low_med_basis + med_high_basis + 
                 (0+ low_basis + low_med_basis + med_high_basis|year_month)+
                 (0+ low_basis + low_med_basis + med_high_basis|COM_TYPE),
               control = lmerControl(optCtrl = list(maxfun = 1e6)))
saveRDS(model1,"/home/xz578/TEJM/TEJM-main/anna/data/prediction_model/model_lmer_B_spline1.rds") #df = 3, degree=2, 3 categories, combine medium to high

