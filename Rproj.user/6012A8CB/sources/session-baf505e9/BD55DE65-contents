```{r}
#get census total population and housing units to compare population per housing unit

pop_hh <- get_acs(geography = "tract",
                      state = 36,
                      geometry = FALSE,
                      variables = c(total_pop = "B00001_001",
                                    housing_units = "B00002_001"),
                      year = 2010,
                      output = "tidy",
                      survey = "acs5") 

pop_hh

pop_hh_gt <- pivot_wider(pop_hh, names_from = variable, values_from = estimate)
pop_hh_gt <- filter_if(pop_hh_gt, is.numeric, all_vars((.) != 0))

pop_hh_gt$pp_per_hh <- pop_hh_gt$total_pop/pop_hh_gt$housing_units

#aggregate to county level (no need)
pop_hh_county <- pop_hh_gt %>% 
  mutate(NAME = tolower(str_extract((NAME), categories))) %>%
  group_by(NAME) %>%
  summarise(tot_pop = sum(total_pop, na.rm = T), tot_hou = sum(housing_units, na.rm = T)) 
pop_hh_county$pp_per_hh <- pop_hh_county$tot_pop/pop_hh_county$tot_hou
head(pop_hh_county)
```

```{r}
#compare population per building from calculation and population per housing unit from census tracts at the tract level

