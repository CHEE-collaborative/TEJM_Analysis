## Group Average 
data_energy <- readRDS("data_table_cat.rds") %>%
  group_by(Median_Income_cat,year, month) %>%
  summarize(Total_Energy = sum(Total_Energy), Households = sum(Households)) %>%
  mutate(normalized_energy_use = Total_Energy/Households) %>%
  mutate(times = paste0(month, ".",year)) %>%
  mutate(times = factor(times)) %>%
  mutate(times2 = ifelse(month == 5, "May", 
                         ifelse(month == 6, "Jun", 
                                ifelse(month == 7, "Jul", 
                                       ifelse(month == 8, "Aug", 
                                              ifelse(month == 9, "Sep", NA)))))) %>%
  mutate(times2 = factor(times2, levels = c("May", "Jun", "Jul", "Aug", "Sep")))

levels(data_energy$Median_Income_cat) <- c("< $50,000","$50,000-$69,999", "$70,000-$89,999", ">= $90,000")

p1 <- ggplot(data_energy, aes(x = times2, y = normalized_energy_use, 
                              color = Median_Income_cat, 
                              group = Median_Income_cat,
                              shape = Median_Income_cat)) +
  geom_line(size = 1) +
  geom_point(size = 2) +
  labs(#title = "Average Energy Use per",
    x = "Month",
    y = "Average energy use per household (Mwh)",
    color = "Income Groups",
    shape = "Income Groups") +
  scale_shape_manual(values = c(16, 17, 18,15)) +
  scale_x_discrete(breaks = function(x) x[seq_along(x) %% 2 == 1]) +
  facet_wrap(~ year, scales = "free_x") +
  theme_bw() +
  theme(legend.position = "right",
        axis.text.x = element_text(size = 12, face = "bold",hjust = 1),  
        axis.text.y = element_text(size = 12, face = "bold"),  
        axis.title.x = element_text(size = 14, face = "bold"), 
        axis.title.y = element_text(size = 14, face = "bold"))
p1
