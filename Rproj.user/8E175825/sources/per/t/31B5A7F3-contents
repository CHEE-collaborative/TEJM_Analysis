## Distribution of HICDD and slopes
set.seed(123)
n <- 100
data <- data.frame(
  HICDD = runif(n, 0, 1),   # Random HICDD values between 0 and 1
  Y = rnorm(n, 50, 10),
  IncomeGroup = factor(sample(c("50,000-69,999", "70,000-89,999", ">= 90,000"), size = n, replace = TRUE))
)

# Create the combined plot
p <- ggplot(data, aes(x = HICDD)) +
  # Add histogram at the top
  geom_histogram(data = data, binwidth = 0.1, fill = "grey70", color = "black") +
  # Add line plot at the bottom
  geom_line(aes(y = Y, group = IncomeGroup, color = IncomeGroup), position = position_dodge(0.1), size = 1) +
  facet_grid(vars(IncomeGroup), scales = "free_y", space = "free_y", switch = "y") +
  labs(
    # title = "Line Plot Grouped by Income with HICDD Distribution",
    x = "HICDD",
    y = "Estimated HICDD:Income"
  ) +
  theme_minimal() +
  theme(
    strip.background = element_blank(),
    strip.placement = "outside"
  )

p

