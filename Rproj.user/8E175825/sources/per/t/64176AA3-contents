Figure_Suppl <- function(){
  
  point_estimate <- lower <- upper <- NULL
  for(i in 1:9){
    tau = i/10
    file_name <- file.path(result_path, "Model_Sensitivity", paste0("model_summary_HICDD_categorical_income_more_",tau,".rds"))
    model <- readRDS(file_name)
    point_estimate <- c(point_estimate, model$tTable[11:16,1])
    lower <- c(lower, model$tTable[11:16,3])
    upper <- c(upper, model$tTable[11:16,4])
  }
  
  quantiles <- c(rep(as.character(1:9/10), each = 6))
  category <- rep(factor(c("$50,000-$59,999","$60,000-$69,999", 
                           "$70,000-$79,999","$80,000-$89,999", 
                           "$90,000-$99,999",">= $100,000"),
                         levels = c("$50,000-$59,999","$60,000-$69,999", 
                                    "$70,000-$79,999","$80,000-$89,999", 
                                    "$90,000-$99,999",">= $100,000")),9)
  slope_income <- data.frame(category = category,
                             quantiles = quantiles,
                             point_estimate = point_estimate,
                             lower = lower,
                             upper = upper)
  
  p1 <- ggplot(slope_income, aes(x = category, y = quantiles, fill = point_estimate)) +
    geom_tile(color = "white") +  
    scale_fill_viridis_c(name = "Point Estimate") +
    theme_minimal() +
    labs(
      y = "Quantiles",
      x = "Income Groups") +
    theme(axis.text = element_text(size = 12, face = "bold"),
          axis.text.x = element_text(size = 8, face = "bold"),
          axis.title = element_text(size = 14, face = "bold"),
          legend.position = "right")
  
  return(p1)
  
}


