################################################################################
######## Function to Compare Actual Energy to Dasyametric Estimates ############
################################################################################

CompareFunction = function(selected_month, selected_year, accumulator) {
  file_name <- paste0("Month", selected_month, "_Year", selected_year)
  file = st_read(here(DATA_DATADIR, "energy_data", paste0(file_name, ".geojson")))
  
  community_energy_data_month_year <- community_energy_data %>%
      filter(month == selected_month, year == selected_year)
  
  # Calculate the sum of the "value" column for each group in community energy dataset
  community_energy_data_month_year <- community_energy_data_month_year %>%
  group_by(ZCTA5CE10) %>%
  summarize(total_value = sum(as.numeric(value)))

  # Merge the dataframes based on the "ZCTA5CE10" column
  comparison_dataframe <- left_join(st_drop_geometry(file[,c("ZCTA5CE10", "total_energy_times_area")]), st_drop_geometry(community_energy_data_month_year[, c("ZCTA5CE10", "total_value")]), by = "ZCTA5CE10")
  
  # create a percent difference column
  comparison_dataframe$percent_difference = round(((comparison_dataframe$total_value - comparison_dataframe$total_energy_times_area)/comparison_dataframe$total_energy_times_area) * 100, 2)
  
  comparison_dataframe$month = selected_month
  comparison_dataframe$year = selected_year
  
  if (is.null(accumulator)) {
    return(comparison_dataframe)
  } else {
    return(rbind(accumulator, comparison_dataframe))
  }
}


months = c("5", "6", "7", "8")
years = c("2016", "2017", "2018", "2019", "2020")
accumulator = NULL

for (selected_year in years) {
  for (selected_month in months) {
    accumulator = CompareFunction(selected_month, selected_year, accumulator)
  }
}

