```{r}
################################################################################
## merging the community level data and the zip code level data and plotting ###
################################################################################

# Find common column names
common_cols <- intersect(colnames(filtered_shape), colnames(c_filtered_shape))

# subset the objects to include only the common columns
filtered_shape <- filtered_shape[, common_cols]
c_filtered_shape <- c_filtered_shape[, common_cols]

# combine the zip code and community level energy data
combined_shape <- rbind(filtered_shape, c_filtered_shape)

# join the energy data with zcta spatial boundaries
combined_shape <- st_join(c_zctas, combined_shape)

# create a column of normalized energy values by number of accounts
combined_shape <- combined_shape %>%
  mutate(normalized_energy_usage = as.numeric(value) / as.numeric(number_of_accounts))

# calculate the log-transformed values for the legend
combined_shape$log_normalized_energy_usage <- log(combined_shape$normalized_energy_usage)
# saveRDS(st_drop_geometry(combined_shape), "/home/xz578/TEJM/TEJM-main/anna/data/energy_data/combined_joined.rds")
# get the min and max values of the log-transformed data
min_value <- 0
max_value <- max(combined_shape$log_normalized_energy_usage, na.rm = TRUE)

# setting coordinates for ggplot
NY_BBOX <- c(46, -80, 40, -71)
xlim <- c(NY_BBOX[2], NY_BBOX[4])
ylim <- c(NY_BBOX[1], NY_BBOX[3])

# loop that plots warm season months for each year to visualize the data
for (year in years) {
  filtered_data <- combined_shape[combined_shape$year == year, ]
  
  for (month in c(5, 6, 7, 8, 9)) {
    filtered_data_month <- filtered_data[filtered_data$month == month, ]
    
    if (all(is.na(filtered_data_month$normalized_energy_usage))) {
      plot_title <- paste("No data for", month, "/", year)
      plot(NA, xlim = c(0, 1), ylim = c(0, 1), main = plot_title, xlab = "", ylab = "")
      next
    }
    
    plot_title <- paste("Combined Community and Zip Code Level Electricity Usage in", month, "/", year, "Plotted by ZCTA")
    
    plot <- ggplot(filtered_data_month) +
      geom_sf(aes(fill = normalized_energy_usage)) +
      scale_fill_gradient(low = "blue", high = "red", na.value = "white",
                          breaks = seq(min_value, max_value, length.out = 5),
                          limits = c(min_value, max_value)) +
      labs(title = plot_title, fill = "Normalized Energy Usage (MWh)") +
      theme_minimal() +
      theme(legend.position = "right")
      
    print(plot)
  }
}

head(combined_shape) 

