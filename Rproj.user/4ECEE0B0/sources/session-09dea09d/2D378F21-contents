# transform the geometry to the appropriate projected CRS (UTM Zone 18N) to calculate area
clean_buildings_transformed <- st_transform(clean_buildings, "+proj=utm +zone=18 +datum=WGS84 +units=m +no_defs")

# calculate the area of each building
