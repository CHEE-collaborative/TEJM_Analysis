```{r}
################################################################################
################################ Zip Code Energy ###############################
################################################################################

# API to retrieve energy data. note the "?$limit=1000000" at the end of the URL.
# Without this, the API will only retrieve the first 1000 records. 
url = "https://data.ny.gov/resource/tzb9-c2c6.geojson?$limit=1000000"

# reading in the energy data
shape = st_read(url)

# filtering the shapefile to contain only electricity data in the warm season months
filtered_shape <- subset(shape, data_field_display_name == "Residential Consumption (R)" & data_class == "electricity" & month %in% c(5, 6, 7, 8, 9) & value > 0)
# filtered_shape <- filtered_shape %>% st_drop_geometry() 
# reading in zip code to ZCTA crosswalk
zip_crosswalk = read_excel(here("anna", "data", "Uploaded Files", "ZIPCodetoZCTACrosswalk2020UDS.xlsx"))
zip_crosswalk = read_excel("/home/xz578/TEJM/TEJM-main/anna/data/Uploaded Files/ZIPCodetoZCTACrosswalk2020UDS.xlsx")
# Join the dataframes based on zip code
energy_per_zcta <- filtered_shape %>%
  left_join(zip_crosswalk, by = c("zip_code" = "ZIP_CODE")) %>%
  dplyr::select(ZCTA, value, number_of_accounts, month, year, utility_display_name) 
# saveRDS(energy_per_zcta,"/home/xz578/TEJM/LQMM/energy_zcta.rds")
# Calculate the sum of energy usage and number of accounts per ZCTA per month per year
energy_per_zcta_summary <- energy_per_zcta %>%
  group_by(ZCTA, month, year) %>%
  summarise(total_energy = sum(as.numeric(value)),
            total_accounts = sum(as.numeric(number_of_accounts)))

# normalize energy usage by number of accounts
energy_per_zcta_summary <- energy_per_zcta_summary %>%
  mutate(normalized_energy_usage = total_energy / total_accounts)

# view data
head(energy_per_zcta_summary)

# view centroids of energy data
# plot(filtered_shape[9])
# saveRDS(energy_per_zcta_summary,"/home/xz578/TEJM/TEJM-main/anna/data/energy_data/energy_zcta_summary.rds")
