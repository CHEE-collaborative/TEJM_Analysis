      output = "wide",
      geometry = geometry,
      state = 36
    ) %>%
      #st_transform(crs = st_crs(4326)) %>%
      # filter(!st_is_empty(.)) %>%
      mutate(Other = Total_pop - White - Black - Asian - Hispanic,
             Size_per_House = Total_pop/Households)
    return(acs_year)
  }
  
