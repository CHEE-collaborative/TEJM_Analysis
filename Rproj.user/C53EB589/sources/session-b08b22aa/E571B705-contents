  community_energy_data <- Energy_community %>% 
    dplyr::select(ZCTA5CE10,com_name,county_name,com_type,geometry) %>% 
    unique() %>% 
    st_drop_geometry() %>% filter(!is.na(value))
  monthly_data <- community_energy_data %>% 
    mutate(value = as.numeric(value)) %>% 
    rename(GEOID = ZCTA5CE10) %>% 
    mutate(year = as.numeric(year),
           month = as.numeric(month)) %>% 
