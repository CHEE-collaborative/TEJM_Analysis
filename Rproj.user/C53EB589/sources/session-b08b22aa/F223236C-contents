Median_Income_cat <- data_table_cat$Median_Income_cat
dummies <- model.matrix(~ Median_Income_cat - 1)
dummy_coefficients_1 <- rowSums(sapply(1:3, function(x){dummies[,x+1] * Model1$theta[8:10][x]}))
dummy_coefficients_2 <- rowSums(sapply(1:3, function(x){dummies[,x+1] * Model2$theta[8:10][x]}))
dummy_coefficients_3 <- rowSums(sapply(1:3, function(x){dummies[,x+1] * Model3$theta[8:10][x]}))

predictions_1_new <- 153*Model1$theta[2] + 153*dummy_coefficients_1
predictions_2_new <- 153*Model2$theta[2] + 153*dummy_coefficients_2
predictions_3_new <- 153*Model3$theta[2] + 153*dummy_coefficients_3

data_predict <- data_table_cat %>%
  mutate(`prediction_0.1` = predictions_1_new,
         `prediction_0.5` = predictions_2_new,
         `prediction_0.9` = predictions_3_new)

data_predict <- data_predict %>%
  pivot_longer(
    cols = starts_with("prediction_"),
    names_to = c("Quantile"),
    names_pattern = "prediction_(.*)", 
    values_to = c("value")
  )

data_predict <- data_predict %>%
  group_by(Median_Income_cat,year) %>%
  summarize(Total_Energy = mean(value, na.rm=T), Households = mean(Households, na.rm=T)) %>%
  mutate(normalized_energy_use = Total_Energy/Households)

p1 <- ggplot(data_predict, aes(x = times2, y = normalized_energy_use, 
