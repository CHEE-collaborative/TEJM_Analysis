model_print <- function(Model){
  
  x <- Model$tTable
  Names <- rownames(x)
  Estimates <- x[,1] * 1000
  lower <- x[,3] * 1000
  upper <- x[,4] * 1000
  
  p_values <- x[,5]
  significance <- ifelse(p_values < 0.001, "***",
                         ifelse(p_values < 0.01, "**",
                                ifelse(p_values < 0.05, "*", "")))
  
  df_estimates <- data.frame(Names = Names, Estimates = Estimates,
                             lower = lower, upper = upper, p_values = p_values,
                             significance = significance)
  
  # Formatted <- with(df_estimates, paste(sprintf("%.4f", Estimates), significance, "\n[", sprintf("%.2f", lower), ", ", sprintf("%.2f", upper), "]", sep = ""))
  cat(sprintf("%s \n%.2f%s \n[%.2f, %.2f]\n\n", Names, Estimates, significance, lower, upper))
}

